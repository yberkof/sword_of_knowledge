{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "lib": ["ES2022"],
    "paths": {
      "@sok/shared": ["../../packages/shared/src/index.ts"],
      "@sok/game-contract": ["../../packages/game-contract/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "server/**/*.ts", "scripts/**/*.ts"]
}
