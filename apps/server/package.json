{
  "name": "@sok/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx --tsconfig tsconfig.json src/main.ts",
    "start": "NODE_ENV=production tsx --tsconfig tsconfig.json src/main.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "db:migrate": "tsx --tsconfig tsconfig.json scripts/migrate.ts",
    "db:seed": "tsx --tsconfig tsconfig.json scripts/seed-questions.ts",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "db:import-firestore": "tsx --tsconfig tsconfig.json scripts/firestore-to-pg.ts"
  },
  "dependencies": {
    "@sok/shared": "0.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.7.0",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
