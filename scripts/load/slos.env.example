# Target load model for ~10k CCU validation (copy to slos.env and tune).
# Peak concurrent Socket.IO connections
SLO_SOCKET_CCU=10000
# Peak HTTP RPS (auth, profile, shop combined envelope)
SLO_HTTP_RPS=500
# Active match rooms during peak (waiting + in-match)
SLO_ACTIVE_ROOMS=2500
# Events per second per room (client + server fan-out)
SLO_EVENTS_PER_ROOM_PER_SEC=20
# Acceptance: p99 room mutation latency ms (server-side; measure via metrics)
SLO_P99_ROOM_TASK_MS=50
# k6 REST VUs (virtual users)
K6_REST_VUS=200
# k6 REST duration
K6_REST_DURATION=5m
