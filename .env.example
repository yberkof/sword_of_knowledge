# Copy to `.env` in the project root. Local DB: `docker compose up -d` then
# `npm run db:migrate` and `npm run db:seed` before `npm run dev`.
# Application tables live in schema `sword_of_knowledge` (see apps/server/migrations).

DATABASE_URL=postgresql://sword:sword_dev@localhost:5432/sword_of_knowledge

# Firebase Admin (required for /api/profile and /api/shop): verify client ID tokens.
# Use service-account.json in project root, or set:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Game server (apps/server)
# PORT=3000
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# WEB_DIST_PATH=/absolute/path/to/apps/web/dist

# Web client (apps/web) — only needed if not using Vite proxy / split origins
# VITE_API_BASE_URL=http://localhost:3000
# VITE_SOCKET_URL=http://localhost:3000
