# Copy to `.env` in the project root. Local DB: `docker compose up -d` then
# `npm run db:migrate` and `npm run db:seed` before `npm run dev`.
# Application tables live in schema `sword_of_knowledge` (see apps/server/migrations).

# JDBC form (recommended):
DATABASE_URL=jdbc:postgresql://localhost:5432/sword_of_knowledge
DB_USER=sword
DB_PASSWORD=sword_dev
# Or libpq form (also accepted): postgresql://sword:sword_dev@localhost:5432/sword_of_knowledge

# Firebase Admin (required for /api/profile and /api/shop): verify client ID tokens.
# Use service-account.json in project root, or set:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Spring Boot (this repo): HTTP PORT default 8080; Socket.IO SOCKET_PORT default 8081
# PORT=8080
# SOCKET_PORT=8081
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
# Local Marefa + Socket.IO without JWT: set true only for dev
# ALLOW_INSECURE_SOCKET=true

# Marefa-game (Next.js): point realtime client at Socket.IO port
# NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8081
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080
