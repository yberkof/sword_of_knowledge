{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores player profile, stats, and inventory.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID." },
        "name": { "type": "string", "description": "Player's display name." },
        "title": { "type": "string", "description": "Player's earned title (e.g., Knowledge Knight)." },
        "level": { "type": "integer", "description": "Player's current level." },
        "xp": { "type": "integer", "description": "Experience points." },
        "gold": { "type": "integer", "description": "Standard currency." },
        "gems": { "type": "integer", "description": "Premium currency." },
        "avatar": { "type": "string", "description": "URL or ID of the avatar image." },
        "rank": { "type": "string", "description": "Current rank (e.g., Bronze, Legend)." },
        "trophies": { "type": "integer", "description": "ELO points/Trophies." },
        "inventory": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of owned power-ups and skins."
        }
      },
      "required": ["uid", "name", "level", "gold", "gems", "xp"]
    },
    "Question": {
      "title": "Trivia Question",
      "description": "A single trivia question with 4 options.",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The question text." },
        "options": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Exactly 4 options."
        },
        "correctIndex": { "type": "integer", "description": "Index of the correct option (0-3)." },
        "category": { "type": "string", "description": "Category (e.g., History, Science)." },
        "difficulty": { "type": "string", "description": "Difficulty level." }
      },
      "required": ["text", "options", "correctIndex", "category"]
    },
    "Match": {
      "title": "Match State",
      "description": "Real-time state of an active match.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Match ID." },
        "players": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "uid": { "type": "string" },
              "name": { "type": "string" },
              "hp": { "type": "integer" },
              "color": { "type": "string" },
              "isCapitalLost": { "type": "boolean" }
            }
          }
        },
        "mapState": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "ownerUid": { "type": "string" },
              "isCapital": { "type": "boolean" },
              "type": { "type": "string" }
            }
          }
        },
        "phase": { "type": "string", "description": "waiting, conquest, duel, resolution, ended" },
        "currentTurnUid": { "type": "string" },
        "activeDuel": {
          "type": "object",
          "properties": {
            "attackerUid": { "type": "string" },
            "defenderUid": { "type": "string" },
            "targetHexId": { "type": "integer" },
            "questionId": { "type": "string" },
            "startTime": { "type": "string", "format": "date-time" },
            "answers": {
              "type": "object",
              "description": "Map of uid to { answerIndex, timeTaken }"
            }
          }
        }
      },
      "required": ["id", "players", "mapState", "phase"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Player data."
    },
    "/questions/{questionId}": {
      "schema": "Question",
      "description": "Trivia question bank."
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Active game sessions."
    }
  }
}
